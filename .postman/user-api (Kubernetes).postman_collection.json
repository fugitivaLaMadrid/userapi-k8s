              "listen": "prerequest",
              "script": {
                "exec": [
                  "const token = pm.collectionVariables.get('accessToken');",
                  "if (!token || token.length === 0) {",
                  "    pm.test('K8s: Access token must be set', function () { pm.expect(token).to.exist; });",
                  "}",
                  "pm.variables.set('uniqueEmail', 'k8s_user_' + Date.now() + '@example.com');",
                  "pm.variables.set('uniqueUsername', 'k8s_user_' + Date.now());"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('K8s: Status is 201 Created', function () { pm.response.to.have.status(201); });",
                  "pm.test('K8s: Response is JSON', function () { pm.response.to.be.json; });",
                  "if (pm.response.text()) {",
                  "    const json = pm.response.json();",
                  "    pm.test('K8s: Created user has an id', function () { pm.expect(json.id).to.not.be.undefined; });",
                  "    pm.test('K8s: Returns submitted username', function () { pm.expect(json.username).to.eql(pm.variables.get('uniqueUsername')); });",
                  "    pm.test('K8s: Returns submitted email', function () { pm.expect(json.email).to.eql(pm.variables.get('uniqueEmail')); });",
                  "}"
                ],
