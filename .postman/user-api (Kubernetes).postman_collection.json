                }
              ]
            },
            "url": {
              "raw": "http://localhost:30180/realms/{{realm}}/protocol/openid-connect/token",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "30180",
              "path": [
                "realms",
                "{{realm}}",
                "protocol",
                "openid-connect",
                "token"
              ]
