        {
          "name": "Delete User",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const token = pm.collectionVariables.get('accessToken');",
                  "if (!token || token.length === 0) {",
                  "    pm.test('K8s: Access token must be set', function () { pm.expect(token).to.exist; });",
                  "} else {",
                  "    // Create a user first to delete",
                  "    pm.sendRequest({",
                  "        url: 'http://localhost:30080/users',",
                  "        method: 'POST',",
                  "        header: {",
                  "            'Content-Type': 'application/json',",
                  "            'Authorization': 'Bearer ' + token,",
                  "        },",
                  "        body: {",
                  "            mode: 'raw',",
                  "            raw: JSON.stringify({",
                  "                username: 'k8s_user_to_delete_' + Date.now(),",
                  "                email: 'k8s_delete_' + Date.now() + '@example.com'",
                  "            })",
                  "        }",
                  "    }, function (err, res) {",
                  "        if (res && res.code === 201) {",
                  "            const json = res.json();",
                  "            pm.variables.set('deleteUserId', json.id);",
                  "            console.log('K8s: Created user with ID: ' + json.id + ' for deletion test');",
                  "        }",
                  "    });",
