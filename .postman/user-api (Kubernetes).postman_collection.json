        {
          "name": "Get All Users",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const token = pm.collectionVariables.get('accessToken');",
                  "console.log('K8s DEBUG: accessToken variable value:', token);",
                  "console.log('K8s DEBUG: accessToken type:', typeof token);",
                  "console.log('K8s DEBUG: accessToken length:', token ? token.length : 'null');",
                  "if (!token || token.length === 0) {",
                  "    console.warn('K8s WARNING: No access token found!');",
                  "    console.warn('Please run \"Get Access Token (Password Grant)\" request first');",
                  "    pm.test('K8s: Access token must be set', function () { pm.expect(token).to.exist; });",
                  "} else {",
                  "    console.log('K8s: Using access token: ' + token.substring(0, 20) + '...');",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('K8s: Status code is 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('K8s: Response time is under 3000ms', function () { pm.expect(pm.response.responseTime).to.be.below(3000); });",
                  "pm.test('K8s: Response is JSON array', function () { pm.expect(pm.response.json()).to.be.an('array'); });",
                  "pm.test('K8s: Response has Content-Type header', function () { pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json'); });"
                ],
                "type": "text/javascript"
              }
            }
